{
  "name": "device-manager",
  "version": "1.0.0",
  "description": "IoT 장비 관리 서버",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "taskkill /F /IM DeviceManager.exe 2>nul & npx pkg . --targets node18-win-x64 --output ../dist/DeviceManager.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "index.html",
      "app.js",
      "logo_ci.png"
    ],
    "targets": [
      "node18-win-x64"
    ]
  },
  "dependencies": {
    "mysql2": "^3.22.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  }
}
